-include .env

install-tools:
	curl -sSfL https://raw.githubusercontent.com/golangci/golangci-lint/master/install.sh | sh -s -- -b $$(shell go env GOPATH)/bin v1.64.8
	go install github.com/sqlc-dev/sqlc/cmd/sqlc@1.26.0
	go install go.uber.org/mock/mockgen@v0.6.0

generate:
	go generate ./...

lint:
	go run github.com/golangci/golangci-lint/cmd/golangci-lint@1.64.8 run ./...

test:
	go test ./... --cover

build:
	docker build -f ./Dockerfile -t $(full_image_tag) ..

publish:
	docker push $(full_image_tag)

run:
	go run ./cmd/grpc-service/...

create-migration:
	migrate create -seq -ext sql -dir db/migrations $(name)

# 	create-migration-old:
#   numbering migrations via timestamps:
# 	migrate create -ext sql -dir db/migrations $(name)

rundb:
	docker run --name users-postgres -p $(DB_PORT):5432 -e POSTGRES_USER=$(DB_USER) -e POSTGRES_PASSWORD=$(DB_PASSWORD) -e POSTGRES_DB=$(DB_NAME) -d postgres:16-alpine